# Copy this to .env and fill in your values
# Never commit .env to git!

# --- Twilio ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=    # Your Twilio phone number

# --- NPS Hotline ---
NPS_HOTLINE_NUMBER=+18559374977        # The NPS hotline number
NPS_EXTENSION=1153                       # DTMF digits to press for the weather report

# --- OpenAI ---
OPENAI_API_KEY=

# --- Garmin inReach delivery ---
# Just the 15-digit IMEI, no country code
# Find it at explore.garmin.com → Devices → your device → Details
# INREACH_EMAIL=123456789012345@inreach.garmin.com
INREACH_EMAIL=


# SMTP — Gmail shown here (works with any provider)
# For Gmail: use an App Password, not your regular password
# Generate one at: myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=    # 16-char Gmail App Password

# --- Server ---
# During dev: use ngrok — run `ngrok http 8000` and paste the https URL here
# In production: your Render/Railway/Lambda URL
PUBLIC_BASE_URL=

